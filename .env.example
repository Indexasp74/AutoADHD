# VaultSandbox Environment Configuration
# Copy this file to .env and fill in your values

# === Required ===

# Vault location (default: ~/VaultSandbox)
VAULT_DIR="$HOME/VaultSandbox"

# --- Obsidian integration (optional) ---
# Where the daily briefing is written. Point at your Obsidian vault's Inbox
# to read deliverables there. Leave unset to use $VAULT_DIR/Inbox.
# OBSIDIAN_INBOX="/mnt/e/Path/To/Obsidian Vault/your-vault/Inbox"
#
# One-way publish of the knowledge base + HOME dashboard into your Obsidian
# vault (via Meta/scripts/publish-to-obsidian.sh, runs every 15 min in cron).
# OBSIDIAN_VAULT  = your Obsidian vault root (REQUIRED for publishing)
# OBSIDIAN_SUBDIR = dedicated subfolder to publish into (default: AutoADHD).
#                   Must be a subfolder — publishing uses rsync --delete scoped
#                   to it, so it never touches the rest of your vault.
# OBSIDIAN_PUBLISH= 1 to enable (default), 0 to disable.
# OBSIDIAN_VAULT="/mnt/e/Path/To/Obsidian Vault/your-vault"
# OBSIDIAN_SUBDIR="AutoADHD"
# OBSIDIAN_PUBLISH="1"

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN="your-telegram-bot-token-here"

# Telegram Chat ID (the bot tells you this on /start)
# Can also be auto-saved to ~/.vault-bot-chat-id
VAULT_BOT_CHAT_ID=""

# Anthropic API Key (for Advisor SDK streaming)
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# === Optional ===

# OpenAI API Key (if using Codex runtime)
# OPENAI_API_KEY="sk-your-key-here"

# Gmail App Password (for email execution workflow)
# Generate at: https://myaccount.google.com/apppasswords
# GMAIL_USER="your-email@gmail.com"
# GMAIL_APP_PASSWORD="your-app-password"

# Whisper Configuration
WHISPER_MODEL="medium"       # tiny, base, small, medium, large
WHISPER_LANGUAGE="en"        # en, de, es, fr, etc.
WHISPER_DEVICE="mps"         # mps (Apple Silicon), cuda (NVIDIA), cpu

# Agent Model Overrides (optional — defaults in agent-runtimes.conf)
# CLAUDE_MODEL="claude-sonnet-4-6"
